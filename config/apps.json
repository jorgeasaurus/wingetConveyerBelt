{
  "apps": [
    {
      "PackageIdentifier": "Google.Chrome",
      "Name": "Google Chrome",
      "VersionDetection": {
        "Type": "api",
        "Url": "https://versionhistory.googleapis.com/v1/chrome/platforms/win/channels/stable/versions",
        "JsonPath": "versions[0].version"
      },
      "InstallerUrls": [
        "https://dl.google.com/chrome/install/GoogleChromeStandaloneEnterprise64.msi",
        "https://dl.google.com/chrome/install/GoogleChromeStandaloneEnterprise.msi"
      ]
    },
    {
      "PackageIdentifier": "Mozilla.Firefox",
      "Name": "Mozilla Firefox",
      "VersionDetection": {
        "Type": "api",
        "Url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "JsonPath": "LATEST_FIREFOX_VERSION"
      },
      "InstallerUrls": [
        "https://download.mozilla.org/?product=firefox-{{version}}-ssl&os=win64&lang=en-US",
        "https://download.mozilla.org/?product=firefox-{{version}}-ssl&os=win&lang=en-US"
      ]
    },
    {
      "PackageIdentifier": "VideoLAN.VLC",
      "Name": "VLC media player",
      "VersionDetection": {
        "Type": "web-scrape",
        "Url": "https://www.videolan.org/vlc/download-windows.html",
        "Pattern": "vlc-([\\d.]+)-win"
      },
      "InstallerUrls": [
        "https://download.videolan.org/vlc/{{version}}/win64/vlc-{{version}}-win64.exe",
        "https://download.videolan.org/vlc/{{version}}/win32/vlc-{{version}}-win32.exe"
      ]
    },
    {
      "PackageIdentifier": "Notepad++.Notepad++",
      "Name": "Notepad++",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/notepad-plus-plus/notepad-plus-plus/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/notepad-plus-plus/notepad-plus-plus/releases/download/v{{version}}/npp.{{version}}.Installer.x64.exe",
        "https://github.com/notepad-plus-plus/notepad-plus-plus/releases/download/v{{version}}/npp.{{version}}.Installer.exe"
      ]
    },
    {
      "PackageIdentifier": "Greenshot.Greenshot",
      "Name": "Greenshot",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/greenshot/greenshot/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/greenshot/greenshot/releases/download/v{{version}}/Greenshot-INSTALLER-{{version}}-RELEASE.exe"
      ]
    },
    {
      "PackageIdentifier": "Microsoft.PowerToys",
      "Name": "PowerToys",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/microsoft/PowerToys/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/microsoft/PowerToys/releases/download/v{{version}}/PowerToysSetup-{{version}}-x64.exe",
        "https://github.com/microsoft/PowerToys/releases/download/v{{version}}/PowerToysSetup-{{version}}-arm64.exe"
      ]
    },
    {
      "PackageIdentifier": "OBSProject.OBSStudio",
      "Name": "OBS Studio",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/obsproject/obs-studio/releases/latest",
        "JsonPath": "tag_name"
      },
      "InstallerUrls": [
        "https://github.com/obsproject/obs-studio/releases/download/{{version}}/OBS-Studio-{{version}}-Windows-x64-Installer.exe"
      ]
    },
    {
      "PackageIdentifier": "ShareX.ShareX",
      "Name": "ShareX",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/ShareX/ShareX/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/ShareX/ShareX/releases/download/v{{version}}/ShareX-{{version}}-setup.exe"
      ]
    },
    {
      "PackageIdentifier": "HandBrake.HandBrake",
      "Name": "HandBrake",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/HandBrake/HandBrake/releases/latest",
        "JsonPath": "tag_name"
      },
      "InstallerUrls": [
        "https://github.com/HandBrake/HandBrake/releases/download/{{version}}/HandBrake-{{version}}-x86_64-Win_GUI.exe",
        "https://github.com/HandBrake/HandBrake/releases/download/{{version}}/HandBrake-{{version}}-arm64-Win_GUI.exe"
      ]
    },
    {
      "PackageIdentifier": "Microsoft.WindowsTerminal",
      "Name": "Windows Terminal",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/microsoft/terminal/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/microsoft/terminal/releases/download/v{{version}}/Microsoft.WindowsTerminal_{{version}}_8wekyb3d8bbwe.msixbundle"
      ]
    },
    {
      "PackageIdentifier": "Brave.Brave",
      "Name": "Brave Browser",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/brave/brave-browser/releases/latest",
        "VersionSource": "name",
        "VersionPattern": "v(?<brave>[\\d.]+).*Chromium (?<chromium>\\d+)",
        "VersionFormat": "{chromium}.{brave}"
      },
      "InstallerVersionTransform": {
        "Pattern": "^\\d+\\.(.*)",
        "Replacement": "$1"
      },
      "InstallerUrls": [
        "https://github.com/brave/brave-browser/releases/download/v{{installerVersion}}/BraveBrowserStandaloneSetup.exe",
        "https://github.com/brave/brave-browser/releases/download/v{{installerVersion}}/BraveBrowserStandaloneSetup32.exe"
      ]
    },
    {
      "PackageIdentifier": "KeePassXCTeam.KeePassXC",
      "Name": "KeePassXC",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/keepassxreboot/keepassxc/releases/latest",
        "JsonPath": "tag_name"
      },
      "InstallerUrls": [
        "https://github.com/keepassxreboot/keepassxc/releases/download/{{version}}/KeePassXC-{{version}}-Win64.msi"
      ]
    },
    {
      "PackageIdentifier": "Telegram.TelegramDesktop",
      "Name": "Telegram Desktop",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/telegramdesktop/tdesktop/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/telegramdesktop/tdesktop/releases/download/v{{version}}/tsetup-x64.{{version}}.exe",
        "https://github.com/telegramdesktop/tdesktop/releases/download/v{{version}}/tsetup.{{version}}.exe"
      ]
    },
    {
      "PackageIdentifier": "DBeaver.DBeaver.Community",
      "Name": "DBeaver Community",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/dbeaver/dbeaver/releases/latest",
        "JsonPath": "tag_name"
      },
      "InstallerUrls": [
        "https://github.com/dbeaver/dbeaver/releases/download/{{version}}/dbeaver-ce-{{version}}-windows-x86_64.exe",
        "https://github.com/dbeaver/dbeaver/releases/download/{{version}}/dbeaver-ce-{{version}}-windows-aarch64.exe"
      ]
    },
    {
      "PackageIdentifier": "Audacity.Audacity",
      "Name": "Audacity",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/audacity/audacity/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "Audacity-"
      },
      "InstallerUrls": [
        "https://github.com/audacity/audacity/releases/download/Audacity-{{version}}/audacity-win-{{version}}-64bit.exe",
        "https://github.com/audacity/audacity/releases/download/Audacity-{{version}}/audacity-win-{{version}}-32bit.exe"
      ]
    },
    {
      "PackageIdentifier": "Git.Git",
      "Name": "Git for Windows",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/git-for-windows/git/releases/latest",
        "VersionSource": "tag_name",
        "VersionPattern": "v(?<base>[\\d.]+)\\.windows\\.(?<rev>\\d+)",
        "VersionFormat": "{base}.{rev}"
      },
      "InstallerVersionTransform": {
        "Pattern": "(\\d+\\.\\d+\\.\\d+)\\.(\\d+)",
        "Replacement": "v$1.windows.$2"
      },
      "InstallerUrls": [
        "https://github.com/git-for-windows/git/releases/download/{{installerVersion}}/Git-{{version}}-64-bit.exe",
        "https://github.com/git-for-windows/git/releases/download/{{installerVersion}}/Git-{{version}}-32-bit.exe"
      ]
    },
    {
      "PackageIdentifier": "GitHub.GitHubDesktop",
      "Name": "GitHub Desktop",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/desktop/desktop/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "release-"
      },
      "InstallerUrls": [
        "https://github.com/desktop/desktop/releases/download/release-{{version}}/GitHubDesktopSetup-x64.exe",
        "https://github.com/desktop/desktop/releases/download/release-{{version}}/GitHubDesktopSetup-x64.msi"
      ]
    },
    {
      "PackageIdentifier": "7zip.7zip",
      "Name": "7-Zip",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/ip7z/7zip/releases/latest",
        "JsonPath": "tag_name"
      },
      "InstallerVersionTransform": {
        "Pattern": "\\.",
        "Replacement": ""
      },
      "InstallerUrls": [
        "https://github.com/ip7z/7zip/releases/download/{{version}}/7z{{installerVersion}}-x64.exe",
        "https://github.com/ip7z/7zip/releases/download/{{version}}/7z{{installerVersion}}.exe"
      ]
    },
    {
      "PackageIdentifier": "dotPDN.PaintDotNet",
      "Name": "Paint.NET",
      "VersionDetection": {
        "Type": "github-release",
        "Url": "https://api.github.com/repos/paintdotnet/release/releases/latest",
        "JsonPath": "tag_name",
        "TagPrefix": "v"
      },
      "InstallerUrls": [
        "https://github.com/paintdotnet/release/releases/download/v{{version}}/paint.net.{{version}}.install.x64.zip",
        "https://github.com/paintdotnet/release/releases/download/v{{version}}/paint.net.{{version}}.install.arm64.zip"
